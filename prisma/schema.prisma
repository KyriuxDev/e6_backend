generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Rol {
  SUPER_ADMIN   // Acceso total al sistema
  ADMIN         // Administrador de un municipio
  COORDINADOR   // Coordinador de una comunidad específica
  USUARIO       // Ciudadano registrado
  OPERADOR      // Operador de cuadrilla — solo ve y actualiza sus asignaciones
}

enum Categoria {
  INFRAESTRUCTURA
  VIALIDAD
  BLOQUEOS
  SEGURIDAD
}

enum EstadoReporte {
  PENDIENTE   // Recién creado, sin atender
  EN_PROCESO  // Siendo atendido por una autoridad
  RESUELTO    // Problema resuelto
  RECHAZADO   // Reporte inválido o duplicado
}

enum FuenteReporte {
  APP_MOVIL
  WEB
  TWITTER
  FACEBOOK
}

enum EstadoComunidad {
  PENDIENTE    // Recién creada, pendiente de aprobación
  ACTIVO       // Comunidad operativa y visible en el mapa
  RECHAZADO    // Solicitud de comunidad rechazada
  SUSPENDIDO   // Comunidad temporalmente inactiva
}

enum NivelAlerta {
  AMARILLA  // IRSU > 50: situación de atención moderada
  ROJA      // IRSU > 100: situación crítica
}

enum EstadoAlerta {
  ACTIVA       // Generada automáticamente, sin atender
  EN_ATENCION  // Tomada por un coordinador o admin
  CERRADA      // Problema resuelto
}


enum EstadoAsignacion {
  ASIGNADA
  EN_CURSO
  COMPLETADA
  CANCELADA
}


model Estado {
  id         Int         @id @default(autoincrement())
  nombre     String      @db.VarChar(100)
  clave      String      @unique @db.Char(2)
  municipios Municipio[]
  @@map("estados")
}

model Municipio {
  id              Int            @id @default(autoincrement())
  nombre          String         @db.VarChar(200)
  clave           String         @unique @db.Char(5)
  estadoId        Int
  estado          Estado         @relation(fields: [estadoId], references: [id])
  comunidades     Comunidad[]
  codigosPostales CodigoPostal[]
  usuarios        Usuario[]
  cuadrillas    Cuadrilla[]
  @@map("municipios")
}

model CodigoPostal {
  id          Int         @id @default(autoincrement())
  codigo      String      @db.Char(5)
  colonia     String      @db.VarChar(200)
  municipioId Int
  municipio   Municipio   @relation(fields: [municipioId], references: [id])
  comunidades Comunidad[]
  @@index([codigo])
  @@map("codigos_postales")
}

model Comunidad {
  id            Int             @id @default(autoincrement())
  nombre        String          @db.VarChar(200)
  slug          String          @unique @db.VarChar(250)
  status        EstadoComunidad @default(PENDIENTE)
  irsuActual    Float           @default(0)
  color         String          @default("#3B82F6") @db.VarChar(7)
  logoUrl       String?
  municipioId   Int
  municipio     Municipio       @relation(fields: [municipioId], references: [id])
  cpId          Int?
  codigoPostal  CodigoPostal?   @relation(fields: [cpId], references: [id])
  usuarios         Usuario[]
  usuariosComunidad UsuarioComunidad[]
  reportes         Reporte[]
  alertas       Alerta[]
  irsuHistorial IrsuHistorial[]
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  @@unique([municipioId, nombre])
  @@map("comunidades")
}

model Usuario {
  id               Int      @id @default(autoincrement())
  email            String   @unique @db.VarChar(150)
  passwordHash     String
  nombre           String?  @db.VarChar(100)
  avatarUrl        String?  @db.VarChar(500)
  rol              Rol      @default(USUARIO)
  activo           Boolean  @default(true)
  municipioId      Int?
  municipio        Municipio? @relation(fields: [municipioId], references: [id])
  comunidadId      Int?
  comunidad        Comunidad? @relation(fields: [comunidadId], references: [id])
  comunidades      UsuarioComunidad[]
  reportes         Reporte[]
  votos            Voto[]
  historial        ReporteHistorial[]
  alertasAsignadas Alerta[]
  asignacionesCuadrilla AsignacionCuadrilla[]
  createdAt        DateTime @default(now())
  @@map("usuarios")
}

model Reporte {
  id           Int           @id @default(autoincrement())
  titulo       String        @db.VarChar(120)
  descripcion  String?       @db.Text
  gravedad     Int
  categoria    Categoria
  estado       EstadoReporte @default(PENDIENTE)
  fuente       FuenteReporte @default(APP_MOVIL)
  latitud      Float
  longitud     Float
  deviceIp     String?       @db.VarChar(45)
  sincronizado Boolean       @default(true)
  voteCount    Int           @default(0)
  usuarioId    Int?
  usuario      Usuario?      @relation(fields: [usuarioId], references: [id])
  comunidadId  Int
  comunidad    Comunidad     @relation(fields: [comunidadId], references: [id])
  fotos        ReporteFoto[]
  votos        Voto[]
  historial    ReporteHistorial[]
  createdAt    DateTime      @default(now())
  deletedAt    DateTime?
  asignaciones  AsignacionCuadrilla[]
  @@map("reportes")
}

model ReporteFoto {
  id        Int      @id @default(autoincrement())
  url       String   @db.Text
  reporteId Int
  reporte   Reporte  @relation(fields: [reporteId], references: [id])
  @@map("reporte_fotos")
}

model Voto {
  id        Int      @id @default(autoincrement())
  usuarioId Int
  usuario   Usuario  @relation(fields: [usuarioId], references: [id])
  reporteId Int
  reporte   Reporte  @relation(fields: [reporteId], references: [id])
  @@unique([usuarioId, reporteId])
  @@map("votos")
}

model ReporteHistorial {
  id             Int           @id @default(autoincrement())
  reporteId      Int
  reporte        Reporte       @relation(fields: [reporteId], references: [id])
  cambiadoPor    Int
  usuario        Usuario       @relation(fields: [cambiadoPor], references: [id])
  estadoAnterior EstadoReporte?
  estadoNuevo    EstadoReporte
  nota           String?       @db.Text
  createdAt      DateTime      @default(now())
  @@map("reporte_historial")
}

model Alerta {
  id          Int          @id @default(autoincrement())
  comunidadId Int
  comunidad   Comunidad    @relation(fields: [comunidadId], references: [id])
  categoria   Categoria
  nivel       NivelAlerta
  estado      EstadoAlerta @default(ACTIVA)
  irsuValor   Float
  asignadoA   Int?
  usuario     Usuario?     @relation(fields: [asignadoA], references: [id])
  atendidaEn  DateTime?
  cerradaEn   DateTime?
  createdAt   DateTime     @default(now())
  @@map("alertas")
}

model IrsuHistorial {
  id               Int        @id @default(autoincrement())
  comunidadId      Int
  comunidad        Comunidad  @relation(fields: [comunidadId], references: [id])
  categoria        Categoria?
  valor            Float
  totalReportes    Int
  gravedadPromedio Float
  tendencia        Float
  createdAt        DateTime   @default(now())
  @@map("irsu_historial")
}

model UsuarioComunidad {
  id          Int       @id @default(autoincrement())
  usuarioId   Int
  usuario     Usuario   @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
  comunidadId Int
  comunidad   Comunidad @relation(fields: [comunidadId], references: [id], onDelete: Cascade)
  esPrincipal Boolean   @default(false)
  creadoEn    DateTime  @default(now())

  @@unique([usuarioId, comunidadId])
  @@map("usuario_comunidades")
}

model Cuadrilla {
  id           Int                   @id @default(autoincrement())
  nombre       String                @db.VarChar(100)
  descripcion  String?               @db.Text
  activa       Boolean               @default(true)
  municipioId  Int
  municipio    Municipio             @relation(fields: [municipioId], references: [id])
  asignaciones AsignacionCuadrilla[]
  createdAt    DateTime              @default(now())
  updatedAt    DateTime              @updatedAt
  @@map("cuadrillas")
}

model AsignacionCuadrilla {
  id           Int              @id @default(autoincrement())
  cuadrillaId  Int
  cuadrilla    Cuadrilla        @relation(fields: [cuadrillaId], references: [id])
  reporteId    Int
  reporte      Reporte          @relation(fields: [reporteId], references: [id])
  estado       EstadoAsignacion @default(ASIGNADA)
  nota         String?          @db.Text
  asignadoEn   DateTime         @default(now())
  iniciadaEn   DateTime?
  completadaEn DateTime?
  asignadoPor  Int
  usuario      Usuario          @relation(fields: [asignadoPor], references: [id])
  @@map("asignaciones_cuadrilla")
}