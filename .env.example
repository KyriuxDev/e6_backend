DATABASE_URL=postgresql://user:password@localhost:5432/irsu_db
JWT_SECRET=your_secret_here
JWT_EXPIRES_IN=7d
PORT=3000
NODE_ENV=development
APP_NAME=Sistema de Reportes Ciudadanos IRSU
APP_DESCRIPTION=API para gestión de reportes ciudadanos geolocalizados con índice IRSU
APP_VERSION=1.0.0

# Límite de reportes diarios para usuarios anónimos (por IP). Default: 3
LIMITE_REPORTES_ANONIMO=3